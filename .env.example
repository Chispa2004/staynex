PORT=3000
USE_MOCK_AI=true
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=15000
AI_CONCIERGE_ENABLED=false
AI_CONCIERGE_MODEL=gpt-4.1-mini
AI_CONCIERGE_TIMEOUT_MS=12000
AI_CONCIERGE_DEBUG=false
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=your_twilio_whatsapp_number
REQUIRE_TWILIO=false
BACKEND_URL=http://localhost:3000
PUBLIC_BACKEND_URL=https://your-public-backend-url.example.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
APALEO_CLIENT_ID=your_apaleo_client_id
APALEO_CLIENT_SECRET=your_apaleo_client_secret
APALEO_ACCOUNT_CODE=your_apaleo_account_code
APALEO_BASE_URL=https://api.apaleo.com
PMS_SECRET_ENCRYPTION_KEY=replace_with_32_byte_base64_or_64_char_hex_key
EXPERIENCE_PROVIDER_EMAIL_MODE=mock
